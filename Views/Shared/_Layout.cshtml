<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.tailwindcss.com"></script>
    <title>@ViewData["Title"] - task4</title>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/task4.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="container mx-auto w-[90%] py-8 flex justify-between items-center border-b border-gray-200">
        @*HEADER LOGO*@
        <div>
            <h2 class="text-4xl font-bold tracking-tighter text-gray-800">COMPOSITION</h2>
            <p class="text-xs text-gray-400 uppercase tracking-widest">Free PSD Website Template</p>
        </div>

        @*NAVBAR*@
        <nav>
            <ul class="flex space-x-6 text-sm font-semibold uppercase tracking-tighter bg-red-600 p-3 rounded-2xl">
                <li>
                    <a href="#" class="!text-white hover:!text-gray-400 transition duration-300">homepage</a>
                </li>
                <li>
                    <a href="#" class="!text-white hover:!text-gray-400 transition duration-300">style demo</a>
                </li>
                <li>
                    <a href="#" class="!text-white hover:!text-gray-400 transition duration-300">full width</a>
                </li>
                <li>
                    <a href="#" class="!text-white hover:!text-gray-400 transition duration-300">dropdown</a>
                </li>
                <li>
                    <a href="#" class="!text-white hover:!text-gray-400 transition duration-300">linktext</a>
                </li>
            </ul>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <footer class="bg-gray-100 text-gray-600 p-10 font-sans mt-auto border-t">
        <div class="container mx-auto w-[90%] grid grid-cols-1 md:grid-cols-3 gap-8 text-sm">

            <div>
                <h3 class="text-xl font-normal text-gray-800 mb-6 uppercase tracking-wider">Latest From The Blog</h3>

                <div class="flex items-start gap-4 mb-6">
                    <div class="border border-gray-300 p-1 bg-white shadow-sm flex-shrink-0">
                        <img src="https://images.pexels.com/photos/262508/pexels-photo-262508.jpeg?auto=compress&cs=tinysrgb&w=95"
                             alt="Blog 1" class="w-[95px] h-[95px] object-cover grayscale hover:grayscale-0 transition duration-500" />
                    </div>
                    <div>
                        <h4 class="text-lg font-medium text-red-600 leading-tight hover:underline cursor-pointer">Metuervestas mus lacinia</h4>
                        <p class="leading-relaxed text-gray-500 mt-1">
                            Convallisjusto vestas mus pellentum aeneansa pibu lum in aliquarm volut pat integset nulla.
                        </p>
                    </div>
                </div>

                <div class="flex items-start gap-4">
                    <div class="border border-gray-300 p-1 bg-white shadow-sm flex-shrink-0">
                        <img src="https://images.pexels.com/photos/3184325/pexels-photo-3184325.jpeg?auto=compress&cs=tinysrgb&w=95"
                             alt="Blog 2" class="w-[95px] h-[95px] object-cover grayscale hover:grayscale-0 transition duration-500" />
                    </div>
                    <div>
                        <h4 class="text-lg font-medium text-red-600 leading-tight hover:underline cursor-pointer">Metuervestas mus lacinia</h4>
                        <p class="leading-relaxed text-gray-500 mt-1">
                            Convallisjusto vestas mus pellentum aeneansa pibu lum in aliquarm volut pat integset nulla.
                        </p>
                    </div>
                </div>
            </div>

            <div>
                <h3 class="text-xl font-normal text-gray-800 mb-6 uppercase tracking-wider">Company Details</h3>

                <div class="space-y-1 mb-6 text-gray-500 italic">
                    <p>Company Name: <span class="text-gray-700 not-italic font-medium">Composition Ltd.</span></p>
                    <p>Street Name & Number: <span class="text-gray-700 not-italic font-medium">123 Business Road</span></p>
                    <p>Town: <span class="text-gray-700 not-italic font-medium">Baku</span></p>
                    <p>Postcode/Zip: <span class="text-gray-700 not-italic font-medium">AZ1000</span></p>
                </div>

                <div class="space-y-1 mb-6 text-gray-500">
                    <p>Tel: <span class="text-gray-700 font-medium">xxxxx xxxxxxxxxx</span></p>
                    <p>Fax: <span class="text-gray-700 font-medium">xxxxx xxxxxxxxxx</span></p>
                    <p>Email: <a href="mailto:contact@mydomain.com" class="text-red-600 hover:underline font-medium">contact@mydomain.com</a></p>
                </div>

                <h4 class="text-lg font-normal text-gray-800 mt-6 mb-2 uppercase text-xs font-bold tracking-widest">Office Hours</h4>
                <div class="space-y-1 text-gray-500 italic">
                    <p>Monday - Friday: <span class="text-gray-700 not-italic">08:00 - 17:30</span></p>
                    <p>Saturday: <span class="text-gray-700 not-italic">08:00 - 13:00</span></p>
                </div>
            </div>

            <div>
                <h3 class="text-xl font-normal text-gray-800 mb-6 uppercase tracking-wider">Contact Us</h3>
                <form action="#" method="post" class="space-y-4">
                    <input type="text" name="name" placeholder="Name"
                           class="w-full p-2 bg-white border border-gray-300 rounded shadow-inner focus:outline-none focus:ring-1 focus:ring-red-500 placeholder-gray-400" />

                    <input type="email" name="email" placeholder="Email"
                           class="w-full p-2 bg-white border border-gray-300 rounded shadow-inner focus:outline-none focus:ring-1 focus:ring-red-500 placeholder-gray-400" />

                    <textarea name="message" placeholder="Message" rows="4"
                              class="w-full p-2 bg-white border border-gray-300 rounded shadow-inner focus:outline-none focus:ring-1 focus:ring-red-500 placeholder-gray-400 resize-none"></textarea>

                    <button type="submit"
                            class="bg-red-600 text-white font-bold px-8 py-3 rounded shadow-md hover:bg-red-700 transition duration-300 uppercase text-xs tracking-widest active:transform active:scale-95">
                        Submit
                    </button>
                </form>
            </div>
        </div>

        <div class="border-t border-gray-300 mt-10 pt-6 text-xs text-gray-500 container mx-auto w-[90%] flex justify-between uppercase tracking-tighter">
            <p>Copyright © 2013 - All Rights Reserved - Domain Name</p>
            <p>Template by <a href="#" class="text-red-600 hover:underline font-bold text-[10px]">OS Templates</a></p>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
